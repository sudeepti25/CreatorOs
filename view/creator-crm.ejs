<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <title>Creator CRM | CreatorOS</title>

  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

   :root {
  --sidebar-bg: #f0ebe3;
  --main-bg: #F5F1EA;
    --bg: #EFE8DC;      /* add this */
  --white: #ffffff;
    /* change to black for retro borders */
  --text: #1a1a1a;
  --muted: #888;
  --accent: #00c6b8;
  --accent-dark: #00b0a3;
  --sidebar-width: 260px;
}

body {
  font-family: 'Space Grotesk', sans-serif;
  color: var(--text);
  background-color: var(--main-bg);   /* was var(--bg) — undefined */
  min-height: 100vh;
  overflow-x: hidden;
}

    a { text-decoration: none; color: inherit; }

    /* ─── LAYOUT ─── */
    .layout {
      display: grid;
      grid-template-columns: var(--sidebar-width) 1fr;
      min-height: 100vh;
    }

    /* ─── SIDEBAR ─── */
    .sidebar {
      background: var(--sidebar-bg);
      border-right: 1px solid var(--border);
      display: flex;
      border: 2px solid #1a1a1a; 
      flex-direction: column;
      padding: 1.5rem 1rem;
      gap: 0.25rem;
    }

    .brand {
      margin-bottom: 1.5rem;
      padding: 0 0.25rem;
    }
    .brand h1 {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #111;
    }
    .brand .beta {
      font-size: 0.72rem;
      color: var(--muted);
      font-weight: 400;
    }

    .nav-item {
       display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 1.5rem 1rem;
 
  font-size: 0.875rem;
  font-weight: 800;
  color: #111111;
  cursor: pointer;
  transition: background 0.15s;
    }
    /* .nav-item:hover { background: rgba(254, 13, 13, 0.05);}*/
    .nav-item:hover { transform: translate(-2px, -2px);       /* lifts on hover */
  box-shadow: 5px 5px 0px #1a1a1a;  }
    .nav-item.active {
      background: var(--accent);
  transform: translate(2px, 2px);
  border:2px solid #1a1a1a   ;      /* presses down on click */
 box-shadow: 3px 3px 0px #1a1a1a;   
  /* remove the transform if you had translateX */
}
    .nav-item svg { width: 16px; height: 16px; flex-shrink: 0; }

    .sidebar-spacer { flex: 1; }

    .upgrade-btn {
      display: block;
      width: 100%;
      padding: 0.75rem;
      background: var(--accent);
      color: #fff;
      box-shadow: 3px 3px 0px #1a1a1a;
      border: 2px solid #1a1a1a;
      
      font-family: 'Space Grotesk', sans-serif;;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      text-align: center;
      margin-bottom: 0.75rem;
      transition: background 0.15s;
    }
    .upgrade-btn:hover { background: var(--accent-dark); }

    .sidebar-footer {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }
    .sidebar-footer .nav-item { font-size: 0.82rem; color: #777; }

    /* ─── MAIN ─── */
    .main {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* ─── TOPBAR ─── */
    .topbar {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.9rem 1.5rem;
      border: 2px solid #1a1a1a; 
      box-shadow: 3px 3px 0px #1a1a1a;
      background: var(--main-bg);
      border-bottom: 1px solid var(--border);
    }

    .search-wrap {
       border: 2px solid #1a1a1a; 
        box-shadow: 3px 3px 0px #1a1a1a;   
           transition: transform 0.2s ease, box-shadow 0.2s ease;
      position: relative;
      flex: 1;
      max-width: 280px;
    }
    .search-wrap svg {
      position: absolute;
      left: 0.75rem;
      top: 50%;
      transform: translateY(-50%);
      width: 15px;
      height: 15px;
      color: #aaa;
    }
    .search-input {
      width: 100%;
      padding: 0.55rem 0.75rem 0.55rem 2.2rem;
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      background: var(--white);
      font-family: 'Space Grotesk', sans-serif;;
      font-size: 0.875rem;
      color: var(--text);
      outline: none;
    }
    .search-input::placeholder { color: #aaa; }

    .topbar-actions {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-left: auto;
    }

    .new-project-btn {
       border: 2px solid #1a1a1a;
         box-shadow: 3px 3px 0px #1a1a1a;     /* retro shadow */  
        transition: transform 0.2s ease,
         box-shadow 0.2s ease;
      padding: 0.55rem 1.1rem;
      background: var(--accent);
      color: #fff;
      
      font-family: 'Space Grotesk', sans-serif;;
      font-size: 0.875rem;
      font-weight: 800;
      cursor: pointer;
      transition: background 0.15s;
    }
    .new-project-btn:hover { background: var(--accent-dark); }

    .icon-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.3rem;
      color: #777;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 0.4rem;
      transition: background 0.15s;
    }
    .icon-btn:hover { background: rgba(0,0,0,0.06); }
    .icon-btn svg { width: 18px; height: 18px; }

    /* ─── CONTENT ─── */
    .content { flex: 1; display: flex; flex-direction: column;
    
    gap:1rem;
    padding:1rem; 
   }

    /* ─── PIPELINE ─── */
    .pipeline {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1rem;
      border-bottom: 1px solid var(--border);
      padding: 1 rem;
      min-height: 480px;
    }

    .pipeline-col {
       
      display: flex;
      flex-direction: column;

    }
    .pipeline-col:last-child { border-right: none; }

    .col-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.15rem;
      border-bottom: 1px solid var(--border);
      background: var(--main-bg);
      border: 3px solid #1a1a1a; 
       box-shadow: 3px 3px 0px #1a1a1a; 
       gap :1rem;
       padding:1 rem;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .col-title {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #333;
    }
    .col-header-action {
      background: none;
      border: none;
      cursor: pointer;
      color: #888;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.15rem;
    }
    .col-header-action svg { width: 16px; height: 16px; }

    .col-body {
      flex: 1;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      background: var(--main-bg);
    }

    /* ─── DEAL CARD ─── */
    .deal-card {
      border: 2px solid #1a1a1a;           /* hard black border */
  border-radius: 0;                    /* flat, no rounding */
  padding: 1rem;
  cursor: pointer;
  position: relative;
  box-shadow: 3px 3px 0px #1a1a1a;     /* retro shadow */
  transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .deal-card:hover {  transform: translate(-2px, -2px) scale(1.02);
  border: 2px solid #f5c842;
  background: #fffdf0;
  box-shadow: 3px 3px 0px #f5c842;    }

    /* hide by default */

/* show on card hover */
.deal-card:hover .deal-status-row {
  display: flex;
}
    .deal-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 0.5rem;
    }

    .category-tag {
      display: inline-flex;
      align-items: center;
      padding: 0.2rem 0.55rem;
      border:2px solid #1a1a1a;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .tag-tech    { background: #dbeafe; color: #1d4ed8; }
    .tag-fintech { background: #dcfce7; color: #15803d; }
    .tag-gaming  { background: #fef9c3; color: #92400e; }
    .tag-lifestyle { background: #f3e8ff; color: #7c3aed; }

    .deal-amount {
      font-size: 0.875rem;
      font-weight: 700;
      color: #222;
    }

    .deal-name {
      font-size: 1rem;
      font-weight: 700;
      color: #111;
      margin-bottom: 0.2rem;
    }
    .deal-sub {
      font-size: 0.78rem;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }

    .deal-status-row {
      display: none;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.6rem;
    }
    .deal-status-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.3rem 0.7rem;
      border: 1px solid var(--border);
      border-radius: 0.35rem;
      font-size: 0.75rem;
      font-weight: 500;
      color: #444;
      background: var(--white);
    }
    .deal-status-tag .check {
      width: 14px; height: 14px;
      background: var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .deal-status-tag .check svg { width: 9px; height: 9px; color: #fff; }

    .emailed-badge {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      background: var(--accent);
      color: #fff;
      font-size: 0.68rem;
      font-weight: 700;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      letter-spacing: 0.03em;
    }

    .deal-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .contact-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .contact-avatar {
      width: 1.8rem;
      height: 1.8rem;
      border-radius: 50%;
      background: linear-gradient(135deg, #a5f3fc, #22d3ee);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      color: #042f3e;
      flex-shrink: 0;
      overflow: hidden;
    }
    .contact-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .contact-name { font-size: 0.78rem; color: #555; font-weight: 500; }

    .deal-icon-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: #aaa;
      display: flex;
      align-items: center;
    }
    .deal-icon-btn svg { width: 14px; height: 14px; }

    /* ─── BOTTOM STRIP ─── */
    .bottom-strip {
       border: 2px solid #1a1a1a;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    /* ─── RECENT CONTACTS TABLE ─── */
   .contacts-panel {
  border-right: 1px solid #e2ddd6;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.25rem 1.5rem;
  border-bottom: 2px solid #1a1a1a;
  background: var(--main-bg);
}

.panel-title {
  font-size: 0.85rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #111;
}

.view-all-link {
  font-size: 0.78rem;
  color: #333;
  text-decoration: underline;
  text-underline-offset: 3px;
  font-weight: 600;
}

.contacts-table {
  width: 100%;
  border-collapse: collapse;
  border: none;        /* remove the black border you added */
}

.contacts-table th {
  text-align: left;
  padding: 0.65rem 1.5rem;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #aaa;
  border-bottom: 1px solid #91908f;
  background: var(--main-bg);
}

.contacts-table td {
  padding: 1rem 1.5rem;
  font-size: 0.875rem;
  border-bottom: 1px solid #91908f;
  color: #333;
}

.contacts-table tr:last-child td { border-bottom: none; }

.contacts-table tbody tr:hover { background: rgba(0,0,0,0.02); }

.contact-company {
  font-weight: 700;
  color: #111;
}

/* rounded pill chips like reference */
.status-chip {
  display: inline-flex;
  padding: 0.25rem 0.85rem;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 500;
  border: 1px solid transparent;
}

.chip-partner     { background: #e6faf8; color: #00857a; border-color: #b2ece7; }
.chip-negotiating { background: #fef9e7; color: #a16207; border-color: #fde68a; }
.chip-active      { background: #eff6ff; color: #2563eb; border-color: #bfdbfe; }

    .action-icon { color: #aaa; cursor: pointer; }
    .action-icon svg { width: 16px; height: 16px; }

    /* ─── INVOICED PANEL ─── */
    /* ─── INVOICED PANEL ─── */
.invoiced-panel {
  display: flex;
  flex-direction: column;
}

.invoiced-header {
  padding: 1.25rem 1.5rem;
  background: var(--accent);
  border-bottom: 2px solid #1a1a1a;
}

.invoiced-header .panel-title {
  color: #fff;
  font-size: 0.85rem;
  font-weight: 800;
  letter-spacing: 0.1em;
}

.invoiced-body {
  padding: 1.5rem;
  flex: 1;
}

.invoiced-amount {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.invoiced-amount .big-num {
  font-size: 2.8rem;
  font-weight: 800;
  color: #111;
  letter-spacing: -0.04em;
  font-family: 'Space Grotesk', sans-serif;
}

.pending-label {
  font-size: 0.85rem;
  color: var(--muted);
  font-weight: 500;
}

.invoice-list {
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
}

.invoice-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.85rem 1rem;
  border: 2px solid #1a1a1a;       /* hard black border */
  border-radius: 0;                 /* flat retro */
  background: var(--white);
  box-shadow: 2px 2px 0px #1a1a1a; /* retro shadow */
}

.invoice-name {
  font-size: 0.875rem;
  font-weight: 600;
  color: #111;
  margin-bottom: 0.2rem;
}

.invoice-due {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.overdue { color: #ef4444; }
.due-in  { color: var(--muted); }

.invoice-amount {
  font-size: 0.95rem;
  font-weight: 800;
  color: #111;
}

.add-invoice-btn {
  width: 2.8rem;
  height: 2.8rem;
  border-radius: 0;                 /* flat retro square */
  background: var(--accent);
  color: #fff;
  border: 2px solid #1a1a1a;
  box-shadow: 3px 3px 0px #1a1a1a;
  font-size: 1.4rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  margin-top: 1rem;
  margin-left: auto;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.add-invoice-btn:hover {
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0px #1a1a1a;
}
  </style>
</head>
